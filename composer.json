{
    "name": "maxime-brochot/touche-pas-au-klaxon",
    "description": "Intranet carpooling application for company employees",
    "type": "project",
    "license": "proprietary",
    "authors": [
        {
            "name": "Maxime Brochot"
        }
    ],
    "require": {
        "izniburak/router": "^3.1",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "phpstan/phpstan": "^2.2"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse"
    }
}
